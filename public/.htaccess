# public/.htaccess
Options -Indexes
RewriteEngine On

# Cho phép serve thẳng file tĩnh (ảnh, css, js, …)
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Còn lại đẩy về index.php (giữ query string)
RewriteRule ^ index.php [QSA,L]
RewriteEngine On
RewriteRule ^$ public/index.php [L]
RewriteRule (.*) public/$1 [L]
